{
  "name": "emoji-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate": "env-cmd -f .env.local npx tsx scripts/generate-meanings.ts",
    "generate:all": "env-cmd -f .env.local npx tsx scripts/generate-meanings.ts --source=all-emojis.json",
    "build-emoji-list": "npx tsx scripts/build-full-emoji-list.ts",
    "create-indexes": "env-cmd -f .env.local npx tsx scripts/create-indexes.ts",
    "generate:comparisons": "env-cmd -f .env.local npx tsx scripts/generate-comparisons.ts",
    "generate:combos": "env-cmd -f .env.local npx tsx scripts/generate-combos.ts",
    "download-kitchen": "env-cmd -f .env.local npx tsx scripts/download-kitchen-data.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@google/generative-ai": "^0.24.1",
    "@upstash/redis": "^1.38.0",
    "env-cmd": "^11.0.0",
    "fuse.js": "^7.3.0",
    "mongodb": "^7.2.0",
    "next": "16.2.6",
    "next-seo": "^7.2.0",
    "p-limit": "^7.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
